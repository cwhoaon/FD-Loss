__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.pyright/
.ruff_cache/
.ipynb_checkpoints/

# Environments and build products
.env
.venv/
venv/
env/
build/
dist/
*.egg-info/

# Editor and OS files
.vscode/
.idea/
.DS_Store

# Keep release directories visible in a fresh clone.
!.gitkeep
!checkpoints/**/.gitkeep
!data/**/.gitkeep
