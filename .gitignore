# Runtime output
work_dirs/
logs/
wandb/
tmp/

# Downloaded data and checkpoints
checkpoints/**/*.pt
checkpoints/**/*.pth
checkpoints/**/*.ckpt
checkpoints/**/*.safetensors
data/*.txt
data/fid_stats/*.npz
data/fid_stats/*.pkl
